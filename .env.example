# -------------------------------------------------------
# APP_ENV controls all environment-dependent behaviour.
# Valid values: local | production
# -------------------------------------------------------
APP_ENV=local

# -------------------------------------------------------
# LOCAL mode — defaults apply if these are omitted:
#   FRONTEND_URLS defaults to http://localhost:3000,http://localhost:3002
#   BFF_URL       defaults to http://localhost:3001
# -------------------------------------------------------
# FRONTEND_URLS=http://localhost:3000,http://localhost:3002
# BFF_URL=http://localhost:3001

# -------------------------------------------------------
# PRODUCTION mode — both values are required (no defaults)
# -------------------------------------------------------
# APP_ENV=production
# FRONTEND_URLS=https://app1.example.com,https://app2.example.com
# BFF_URL=https://api.example.com

# -------------------------------------------------------
# Required in all modes
# -------------------------------------------------------
WORKOS_API_KEY=your_workos_api_key_here
WORKOS_CLIENT_ID=your_workos_client_id_here
SESSION_SECRET=a_long_random_secret_string
